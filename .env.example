# Anthropic API key. Get one at https://console.anthropic.com/
# If unset, the service runs in "stub mode": every /ingest call returns a
# canned, clearly-labeled result instead of calling the model, so the rest
# of the pipeline (parsing, HTTP, dashboard) still works end to end.
ANTHROPIC_API_KEY=

# Optional: override the model used for extraction. Defaults to Claude
# Sonnet 5 -- a good cost/quality balance for structured extraction. Use
# claude-opus-4-8 if you want the most capable model regardless of cost,
# or claude-haiku-4-5 for the cheapest/fastest option.
RFQ_MODEL=claude-sonnet-5
